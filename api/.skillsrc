# Auto-detected configuration generated by agent-skills-standard init
#
# Presence in 'skills' list = Active. To disable a skill, remove it from the list.
# 'exclude': IDs of sub-skills to skip during sync (auto-populated with undetected skills).
# 'custom_overrides': IDs of skills to PROTECT. Use this if you have modified a standard 
# skill locally and don't want the CLI to overwrite it.
#
# Run 'ags list-skills' to view all available skills.
#
# SDLC support skills such as quality-engineering are included by default.
# Specialist definitions are synced separately as native sub-agents, not skills.
#
registry: https://github.com/HoangNguyen0403/agent-skills-standard
agents:
  - antigravity
skills:
  spring-boot:
    ref: spring-boot-v1.3.3
  java:
    ref: java-v1.3.3
  common:
    ref: common-v2.0.9
    exclude:
      - common-accessibility
      - common-mobile-animation
      - common-mobile-ux-core
      - common-store-changelog
      - common-ui-design
  quality-engineering:
    ref: quality-engineering-v1.5.0
  database:
    ref: database-v1.3.4
    exclude:
      - database-postgresql
      - database-mongodb
      - database-redis
custom_overrides: []
workflows:
  - sdlc
  - brainstorm-feature
  - code-review
  - codebase-review
  - design-solution
  - deploy-release
  - plan-feature
  - implementation-readiness
  - review-ticket
  - traceability-audit
  - session-report
  - publish-notes
  - retro-learn
  - skill-benchmark
  - pentest
  - dev-fix
  - implement-feature
  - verify-work
  - verify-bug
  - security-test
mcp:
  enabled: true
  scope: project
  prompted: true
